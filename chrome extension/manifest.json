{
  "manifest_version": 3,
  "name": "MeeTunnel Sidebar",
  "version": "1.0",
  "description": "Control QR Capture directly from the Google Meet sidebar.",
  "permissions": ["sidePanel", "activeTab", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}